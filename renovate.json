{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automergeStrategy": "merge-commit",
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^rust-toolchain\\.toml$/"],
      "matchStrings": ["channel\\s*=\\s*\"(?<currentValue>[0-9.]+)\""],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "rust-lang/rust",
      "depNameTemplate": "rust"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^.github/workflows/.+\\.yaml$/"],
      "matchStrings": ["version: (?<currentValue>[0-9.]+) # renovate: zig-version"],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "ziglang/zig",
      "depNameTemplate": "zig"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^.github/workflows/.+\\.yaml$/"],
      "matchStrings": ["CARGO_ZIGBUILD_VERSION=(?<currentValue>[0-9.]+)"],
      "datasourceTemplate": "crate",
      "packageNameTemplate": "cargo-zigbuild",
      "depNameTemplate": "cargo-zigbuild"
    }
  ]
}
